# Environment Variables for Intelligent Document Automation
# Copy this file to .env and adjust values as needed

# Application Settings
APP_NAME=Intelligent Document Automation
APP_VERSION=1.0.0
DEBUG=false

# Server Settings
HOST=127.0.0.1
PORT=5000
MAX_CONTENT_LENGTH=25

# File Upload Settings
MAX_FILE_SIZE=25
MAX_FILES_PER_UPLOAD=10

# Processing Settings
OCR_ENGINE=tesseract
OCR_DPI=200
OCR_LANGUAGE=eng

# Matching Settings
PATTERN_SCORE_WEIGHT=0.6
SEMANTIC_SCORE_WEIGHT=0.4
MATCH_DECISION_THRESHOLD=0.75

# Output Settings
OUTPUT_FORMAT=excel
INCLUDE_COLOR_CODING=true
INCLUDE_CONFIDENCE_SCORES=true

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security Settings
SECRET_KEY=document-automation-demo
ENABLE_CORS=false
